fn_LoadFunctions()
{
  ## Load Functions from a directory based on a search criteria
  ## $1 Directory
  ## $2 Search string
  ## $3 Display false|true
  ##   Next
  ##   -d    dir
  ##   -pre  pre search
  ##   -post post search
  ## local dir_Directory="$(basename ${1})"
  local dir_Directory="${1}"
  local    str_Search="${2}"
  # local     b_Display="${3:-true}"
  local      b_Errors=0
  local  str_EachFile=
  ##[[ ${b_Display} ]] || printf "\nLoading %s\n" "${dir_Directory}"
  if [ -d "${dir_Directory}" ] ; then
    SAVEIFS=$IFS
    IFS=$(echo -en "\n\b")
    #printf "[ ] %s - %s\n"  $(dirname ${each_Plugin##${dir_Plugins}})  $(basename ${each_Plugin})

    #arr_Functions=$(find -L "${dir_Directory}" -name "${str_Search}*" | sed 's/ /\\ /g')
    arr_Functions=$(find -L "${dir_Directory}" -name "${str_Search}*" | sort )
    for str_EachFile in ${arr_Functions} ; do
      if [ -r "${str_EachFile}" ] ; then
        [[ ${b_NonInteractive} ]] || printf "%15s: %15s" "$(basename "$(dirname "${str_EachFile##${dir_Directory}}")")" "${str_EachFile#${dir_Directory}/*${str_Search}}"

        # Sanitize the file path to avoid traversal and injection
        if [[ "${str_EachFile}" == *".."* ]]; then
          printf "%10s\n" "ERROR" && echo "Rejected ${str_EachFile}: directory traversal detected" && b_Errors=1 && continue
        fi
        if command -v readlink >/dev/null 2>&1 ; then
          realpath_file=$(readlink -f -- "${str_EachFile}" 2>/dev/null || true)
          realpath_dir=$(readlink -f -- "${dir_Directory}" 2>/dev/null || true)
          if [[ -n "${realpath_file}" && -n "${realpath_dir}" ]]; then
            case "${realpath_file}" in
              "${realpath_dir}"/*) : ;;
              *) printf "%10s\n" "ERROR" && echo "Rejected ${str_EachFile}: outside ${dir_Directory}" && b_Errors=1 && continue ;;
            esac
          fi
        fi
        if echo "${str_EachFile}" | grep -qE '[^[:alnum:]/_. -]'; then
          printf "%10s\n" "ERROR" && echo "Rejected ${str_EachFile}: invalid characters in path" && b_Errors=1 && continue
        fi

        # If loading plugins (SP_), perform additional validation to reduce malicious content
        if [[ "${dir_Directory}" == "${dir_Plugins}" || "${str_Search}" == SP_* ]] ; then
          # Reject obvious dangerous constructs except when they appear inside Task "..." or Task '...'
          offending=$(grep -nE '(^|[^a-zA-Z0-9_])(eval|exec|sudo|rm[[:space:]]+-rf|mkfs\.|\bdd\b|:>\s*/dev|/dev/tcp|curl[[:space:]]+.*\|[[:space:]]*sh|wget[[:space:]]+.*\|[[:space:]]*sh)' "${str_EachFile}" | grep -v -E "(Task|Try|Message|Manual|Warning|Error)[[:space:]]*[\"']" || true)
          if [[ -n "${offending}" ]] ; then
            printf "%10s\n" "REJECTED" && echo " - contains disallowed constructs outside Task functions" && b_Errors=1 && continue
          fi
          # Ensure the primary function defined in the plugin matches the filename (for SP_ plugins)
          if [[ "$(basename "${str_EachFile}")" == SP_* ]] ; then
            base_name=$(basename "${str_EachFile}")
            sanitized_name=${base_name//-/_}
            fn_candidate=$(grep -m1 -E '^[[:space:]]*([A-Za-z_][A-Za-z0-9_-]*)[[:space:]]*\(\)' "${str_EachFile}" | sed -E 's/^[[:space:]]*([A-Za-z_][A-Za-z0-9_-]*).*$/\1/' || true)
            # If no valid function name found, try the sanitized variant (filename with - -> _)
            if [[ -z "${fn_candidate}" ]] ; then
              fn_candidate=$(grep -m1 -E "^[[:space:]]*${sanitized_name}[[:space:]]*\(\)" "${str_EachFile}" | sed -E 's/^[[:space:]]*([A-Za-z_][A-Za-z0-9_-]*).*$/\1/' || true)
            fi
            if [[ -n "${fn_candidate}" ]] ; then
              # Allow function names that match the filename or the sanitized filename
              if [[ "${fn_candidate}" != "${base_name}" && "${fn_candidate}" != "${sanitized_name}" ]] ; then
                printf "%10s " "REJECTED" && echo " - does not match filename ${base_name} (or sanitized ${sanitized_name})" && b_Errors=1 && continue
              fi
              # If the function uses the sanitized name, create a stable wrapper (sanitized -> safe wrapper)
              if [[ "${fn_candidate}" == "${sanitized_name}" ]] ; then
                safe_wrapper=${base_name//[^a-zA-Z0-9_]/_}
                # create wrapper only if function names differ
                if [[ "${safe_wrapper}" != "${fn_candidate}" ]] ; then
                  eval "${safe_wrapper}() { ${fn_candidate} \"\$@\"; }" 2>/dev/null || :
                fi
              fi
            else
              printf "%10s" "REJECTED" && echo " - no function declaration found" && b_Errors=1 && continue
            fi
          fi
        fi

        # Only run the top-level executable check for plugin files
        if [[ "${dir_Directory}" == "${dir_Plugins}" || "${str_Search}" == SP_* ]] ; then
          # Bash the function file for errors before loading it
          # Reject files that contain executable code outside of function bodies (allow shebang and comments)
          top_level_offenders=$(
            lineno=0
            depth=0
            expect_brace=0
            while IFS= read -r line || [[ -n $line ]]; do
              lineno=$((lineno+1))
              if [[ ${lineno} -eq 1 && ${line} == \#!* ]] ; then
                continue
              fi
              if [[ ${depth} -eq 0 ]] ; then
                [[ "${line//[[:space:]]/}" == "" ]] && continue
                [[ "${line}" =~ ^[[:space:]]*# ]] && continue
                # Function header with brace on same line: name() { ...
                if [[ "${line}" =~ ^[[:space:]]*[A-Za-z_][A-Za-z0-9_-]*[[:space:]]*\(\)[[:space:]]*\{ ]] ; then
                  open=$(tr -cd '{' <<<"${line}" | wc -c)
                  close=$(tr -cd '}' <<<"${line}" | wc -c)
                  depth=$((open - close))
                  continue
                fi
                # Function header on its own line: name()
                if [[ "${line}" =~ ^[[:space:]]*[A-Za-z_][A-Za-z0-9_-]*[[:space:]]*\(\)[[:space:]]*$ ]] ; then
                  expect_brace=1
                  continue
                fi
                # If we were expecting a brace, allow intervening comments/blank lines until brace
                if [[ ${expect_brace} -eq 1 ]] ; then
                  [[ "${line//[[:space:]]/}" == "" ]] && continue
                  [[ "${line}" =~ ^[[:space:]]*# ]] && continue
                  if [[ "${line}" =~ ^[[:space:]]*\{ ]] ; then
                    open=$(tr -cd '{' <<<"${line}" | wc -c)
                    close=$(tr -cd '}' <<<"${line}" | wc -c)
                    depth=$((open - close))
                    expect_brace=0
                    continue
                  else
                    # Unexpected content after function header without brace
                    printf "%s:%s\n" "${lineno}" "${line}"
                    continue
                  fi
                fi
                # anything else at top level is offending
                printf "%s:%s\n" "${lineno}" "${line}"
                continue
              else
                open=$(tr -cd '{' <<<"${line}" | wc -c)
                close=$(tr -cd '}' <<<"${line}" | wc -c)
                depth=$((depth + open - close))
                if [[ ${depth} -le 0 ]] ; then
                  depth=0
                fi
              fi
            done < "${str_EachFile}"
          ) || true
          if [[ -n "${top_level_offenders}" ]] ; then
            printf "%10s" "REJECTED" && echo " - contains executable code outside function definitions" && b_Errors=1 && continue
          fi
        fi

        if bash -n "${str_EachFile}" ; then
          source "${str_EachFile}"
          [[ ${b_NonInteractive} ]] || printf "%10s\n" "OK"
        else
          printf "%10s\n" "ERROR" && b_Errors=1
        fi

      else
        echo "Cannot access <${str_EachFile}>"
      fi
    done
    IFS=$SAVEIFS
  else
    :
        ##echo "$(pwd) ${dir_Directory} could not be found"
  fi

  [[ ${b_Errors} -ge 1 ]] && printf "\n\nWARNING: Some plugins reported error"
  :
}
