fn_BaseDir()
{
  ## Taking a directory name as a parameter, output the full absolute path
  ## It could be absolute or relative so check and clean out any <dir>/../<dir> additions
  ## if ${1} starts "/"
  [ -d "${1}" ] || return 1
  cd "${1}" && pwd || return 1
}

